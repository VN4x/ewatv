[Unit]
Description=EWATV Playout Backend
After=ewatv-postgres.service ewatv-redis.service
Requires=ewatv-postgres.service ewatv-redis.service

[Container]
ContainerName=ewatv-playout
Image=localhost/ewatv-playout:latest
PublishPort=8090:8090
Volume=ewatv_playout_data.volume:/data:Z
Environment=EWATV_DATABASE_URL=postgres://ewatv@ewatv-postgres:5432/ewatv_playout?sslmode=disable
Environment=EWATV_REDIS_URL=redis://ewatv-redis:6379/0
Environment=EWATV_LOGGING_FORMAT=json
Environment=EWATV_STORAGE_ROOT=/data
Secret=ewatv_jwt_secret,type=env,target=EWATV_AUTH_SUPABASE_JWT_SECRET
HealthCmd=curl -sf http://127.0.0.1:8090/health

[Service]
Restart=always

[Install]
WantedBy=default.target
