# Infisical → Podman environment mapping (standalone — no Supabase)
# Usage: infisical run --env=production -- podman compose -f deployments/podman/compose.yaml up -d

EWATV_DATABASE_URL=postgres://ewatv:${DB_PASSWORD}@postgres:5432/ewatv_playout?sslmode=disable
EWATV_REDIS_URL=redis://redis:6379/0
EWATV_AUTH_JWT_SECRET=
EWATV_LOGGING_FORMAT=json
EWATV_PLAYOUT_PUBLIC_BASE_URL=https://playout.example.com
