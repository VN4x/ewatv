# Supabase (Lovable Cloud)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Mist VPS (deploy/mist)
MIST_API_URL=http://127.0.0.1:4242
MIST_API_USER=admin
MIST_API_PASSWORD=
MIST_PLAYLIST_SYNC_URL=http://127.0.0.1/playlist-sync
MIST_PLAYLIST_SYNC_TOKEN=dev-sync-token
MIST_MEDIA_ROOT=/media
MIST_GAP_ASSET_PATH=/media/gap-black.mp4
MIST_DEFAULT_GAP_MS=1500
VITE_MIST_HLS_BASE=http://127.0.0.1/hls
VITE_OVERLAY_LOGO_URL=/overlay-logo.png

# Mega.io S3-compatible (optional, for signMegaUrl / direct smoke)
MEGA_S3_ENDPOINT=
MEGA_S3_ACCESS_KEY=
MEGA_S3_SECRET_KEY=
MEGA_S3_BUCKET=
MEGA_S3_REGION=us-east-1

# Autopilot cron (POST /api/cron/autopilot)
AUTOPILOT_CRON_SECRET=
AUTOPILOT_TIMEZONE=Europe/Helsinki
